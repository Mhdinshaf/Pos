<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #1a1a2e;" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pos.controller.ProductController">
    <children>
        <VBox spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <!-- Header with Back Button -->
                <HBox spacing="20.0" alignment="CENTER_LEFT">
                    <children>
                        <Button fx:id="btnBackToDashboard" mnemonicParsing="false" onAction="#handleBackToDashboard" prefHeight="30.0" prefWidth="80.0" style="-fx-background-color: #607D8B; -fx-text-fill: #ffffff; -fx-background-radius: 5; -fx-cursor: hand;" text="← Back">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Button>
                        <Label text="PRODUCT MANAGEMENT" textFill="#e94560">
                            <font>
                                <Font name="System Bold" size="24.0" />
                            </font>
                        </Label>
                    </children>
                </HBox>

                <!-- Search Section -->
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <children>
                        <Label text="Search:" textFill="#ffffff">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <TextField fx:id="txtSearch" prefWidth="300.0" promptText="Search by product name..." style="-fx-background-color: #0f3460; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #808080; -fx-background-radius: 5;">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </TextField>
                    </children>
                </HBox>

                <!-- Table Section -->
                <TableView fx:id="tblProducts" prefHeight="200.0" style="-fx-background-color: #16213e; -fx-control-inner-background: #16213e; -fx-table-cell-border-color: #0f3460;">
                    <columns>
                        <TableColumn fx:id="colProductId" prefWidth="80.0" text="ID" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colName" prefWidth="180.0" text="Name" />
                        <TableColumn fx:id="colCategory" prefWidth="120.0" text="Category" />
                        <TableColumn fx:id="colPrice" prefWidth="100.0" text="Price" style="-fx-alignment: CENTER-RIGHT;" />
                        <TableColumn fx:id="colQuantity" prefWidth="80.0" text="Qty" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colSupplier" prefWidth="150.0" text="Supplier" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <!-- Form Section -->
                <VBox spacing="15.0" style="-fx-background-color: #16213e; -fx-background-radius: 10;">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                    <children>
                        <Label text="Product Details" textFill="#e94560">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>

                        <HBox spacing="20.0">
                            <children>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Name" textFill="#ffffff">
                                            <font>
                                                <Font size="12.0" />
                                            </font>
                                        </Label>
                                        <TextField fx:id="txtName" promptText="Enter product name" style="-fx-background-color: #0f3460; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #808080; -fx-background-radius: 5;">
                                            <font>
                                                <Font size="14.0" />
                                            </font>
                                        </TextField>
                                    </children>
                                </VBox>

                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Category" textFill="#ffffff">
                                            <font>
                                                <Font size="12.0" />
                                            </font>
                                        </Label>
                                        <ComboBox fx:id="cmbCategory" maxWidth="Infinity" promptText="Select category" style="-fx-background-color: #0f3460; -fx-background-radius: 5;" />
                                    </children>
                                </VBox>

                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Price" textFill="#ffffff">
                                            <font>
                                                <Font size="12.0" />
                                            </font>
                                        </Label>
                                        <TextField fx:id="txtPrice" promptText="Enter price" style="-fx-background-color: #0f3460; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #808080; -fx-background-radius: 5;">
                                            <font>
                                                <Font size="14.0" />
                                            </font>
                                        </TextField>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <HBox spacing="20.0">
                            <children>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Quantity" textFill="#ffffff">
                                            <font>
                                                <Font size="12.0" />
                                            </font>
                                        </Label>
                                        <TextField fx:id="txtQuantity" promptText="Enter quantity" style="-fx-background-color: #0f3460; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #808080; -fx-background-radius: 5;">
                                            <font>
                                                <Font size="14.0" />
                                            </font>
                                        </TextField>
                                    </children>
                                </VBox>

                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Supplier" textFill="#ffffff">
                                            <font>
                                                <Font size="12.0" />
                                            </font>
                                        </Label>
                                        <ComboBox fx:id="cmbSupplier" maxWidth="Infinity" promptText="Select supplier" style="-fx-background-color: #0f3460; -fx-background-radius: 5;" />
                                    </children>
                                </VBox>

                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <!-- Empty spacer -->
                                </VBox>
                            </children>
                        </HBox>

                        <!-- Buttons -->
                        <HBox spacing="15.0" alignment="CENTER">
                            <VBox.margin>
                                <Insets top="10.0" />
                            </VBox.margin>
                            <children>
                                <Button fx:id="btnAdd" mnemonicParsing="false" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #4CAF50; -fx-text-fill: #ffffff; -fx-background-radius: 5; -fx-cursor: hand;" text="Add">
                                    <font>
                                        <Font name="System Bold" size="13.0" />
                                    </font>
                                </Button>
                                <Button fx:id="btnUpdate" mnemonicParsing="false" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #2196F3; -fx-text-fill: #ffffff; -fx-background-radius: 5; -fx-cursor: hand;" text="Update">
                                    <font>
                                        <Font name="System Bold" size="13.0" />
                                    </font>
                                </Button>
                                <Button fx:id="btnDelete" mnemonicParsing="false" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #e94560; -fx-text-fill: #ffffff; -fx-background-radius: 5; -fx-cursor: hand;" text="Delete">
                                    <font>
                                        <Font name="System Bold" size="13.0" />
                                    </font>
                                </Button>
                                <Button fx:id="btnClear" mnemonicParsing="false" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #607D8B; -fx-text-fill: #ffffff; -fx-background-radius: 5; -fx-cursor: hand;" text="Clear">
                                    <font>
                                        <Font name="System Bold" size="13.0" />
                                    </font>
                                </Button>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
