<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #1a1f36;" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pos.controller.SupplierController">
    <children>
        <VBox spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <!-- Header with Back Button -->
                <HBox spacing="20.0" alignment="CENTER_LEFT">
                    <children>
                        <Button fx:id="btnBackToDashboard" mnemonicParsing="false" onAction="#handleBackToDashboard" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #3a86ff; -fx-text-fill: #ffffff; -fx-background-radius: 8; -fx-cursor: hand;" text="← Back">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Button>
                        <Label text="SUPPLIER MANAGEMENT" textFill="#3a86ff">
                            <font>
                                <Font name="System Bold" size="24.0" />
                            </font>
                        </Label>
                    </children>
                </HBox>

                <!-- Search Section -->
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <children>
                        <Label text="Search:" textFill="#ffffff">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <TextField fx:id="txtSearch" prefWidth="300.0" promptText="Search by supplier name..." style="-fx-background-color: #2d3250; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #808080; -fx-background-radius: 8; -fx-border-color: #3a86ff; -fx-border-radius: 8;">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </TextField>
                    </children>
                </HBox>

                <!-- Table Section -->
                <TableView fx:id="tblSuppliers" prefHeight="250.0" style="-fx-background-color: #2d3250; -fx-control-inner-background: #2d3250; -fx-table-cell-border-color: #1a1f36;">
                    <columns>
                        <TableColumn fx:id="colSupplierId" prefWidth="100.0" text="ID" style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colName" prefWidth="200.0" text="Name" />
                        <TableColumn fx:id="colEmail" prefWidth="250.0" text="Email" />
                        <TableColumn fx:id="colPhone" prefWidth="180.0" text="Phone" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <!-- Form Section -->
                <VBox spacing="15.0" style="-fx-background-color: #2d3250; -fx-background-radius: 10;">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                    <children>
                        <Label text="Supplier Details" textFill="#3a86ff">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>

                        <HBox spacing="20.0">
                            <children>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Name" textFill="#ffffff">
                                            <font>
                                                <Font size="12.0" />
                                            </font>
                                        </Label>
                                        <TextField fx:id="txtName" promptText="Enter supplier name" style="-fx-background-color: #2d3250; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #808080; -fx-background-radius: 8; -fx-border-color: #3a86ff; -fx-border-radius: 8;">
                                            <font>
                                                <Font size="14.0" />
                                            </font>
                                        </TextField>
                                    </children>
                                </VBox>

                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Email" textFill="#ffffff">
                                            <font>
                                                <Font size="12.0" />
                                            </font>
                                        </Label>
                                        <TextField fx:id="txtEmail" promptText="Enter email address" style="-fx-background-color: #2d3250; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #808080; -fx-background-radius: 8; -fx-border-color: #3a86ff; -fx-border-radius: 8;">
                                            <font>
                                                <Font size="14.0" />
                                            </font>
                                        </TextField>
                                    </children>
                                </VBox>

                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Phone" textFill="#ffffff">
                                            <font>
                                                <Font size="12.0" />
                                            </font>
                                        </Label>
                                        <TextField fx:id="txtPhone" promptText="Enter phone number" style="-fx-background-color: #2d3250; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #808080; -fx-background-radius: 8; -fx-border-color: #3a86ff; -fx-border-radius: 8;">
                                            <font>
                                                <Font size="14.0" />
                                            </font>
                                        </TextField>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <!-- Buttons -->
                        <HBox spacing="15.0" alignment="CENTER">
                            <VBox.margin>
                                <Insets top="10.0" />
                            </VBox.margin>
                            <children>
                                <Button fx:id="btnAdd" mnemonicParsing="false" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #3a86ff; -fx-text-fill: #ffffff; -fx-background-radius: 8; -fx-cursor: hand;" text="Add">
                                    <font>
                                        <Font name="System Bold" size="13.0" />
                                    </font>
                                </Button>
                                <Button fx:id="btnUpdate" mnemonicParsing="false" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #3a86ff; -fx-text-fill: #ffffff; -fx-background-radius: 8; -fx-cursor: hand;" text="Update">
                                    <font>
                                        <Font name="System Bold" size="13.0" />
                                    </font>
                                </Button>
                                <Button fx:id="btnDelete" mnemonicParsing="false" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #3a86ff; -fx-text-fill: #ffffff; -fx-background-radius: 8; -fx-cursor: hand;" text="Delete">
                                    <font>
                                        <Font name="System Bold" size="13.0" />
                                    </font>
                                </Button>
                                <Button fx:id="btnClear" mnemonicParsing="false" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #3a86ff; -fx-text-fill: #ffffff; -fx-background-radius: 8; -fx-cursor: hand;" text="Clear">
                                    <font>
                                        <Font name="System Bold" size="13.0" />
                                    </font>
                                </Button>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
