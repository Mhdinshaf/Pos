<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="500.0" style="-fx-background-color: #1a1a2e;" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pos.controller.RegisterController">
    <children>
        <VBox alignment="CENTER" spacing="12.0" style="-fx-background-color: #16213e; -fx-background-radius: 10;" AnchorPane.bottomAnchor="40.0" AnchorPane.leftAnchor="80.0" AnchorPane.rightAnchor="80.0" AnchorPane.topAnchor="40.0">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
            <children>
                <Label text="CLOTHIFY STORE" textFill="#e94560">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>
                <Label text="Create a new account" textFill="#a0a0a0">
                    <font>
                        <Font size="12.0" />
                    </font>
                </Label>
                
                <VBox spacing="5.0">
                    <children>
                        <Label text="Username" textFill="#ffffff">
                            <font>
                                <Font size="12.0" />
                            </font>
                        </Label>
                        <TextField fx:id="txtUsername" promptText="Enter username" style="-fx-background-color: #0f3460; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #808080; -fx-background-radius: 5;">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </TextField>
                    </children>
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </VBox>
                
                <VBox spacing="5.0">
                    <children>
                        <Label text="Password" textFill="#ffffff">
                            <font>
                                <Font size="12.0" />
                            </font>
                        </Label>
                        <PasswordField fx:id="txtPassword" promptText="Enter password (min 6 characters)" style="-fx-background-color: #0f3460; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #808080; -fx-background-radius: 5;">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </PasswordField>
                    </children>
                </VBox>
                
                <VBox spacing="5.0">
                    <children>
                        <Label text="Confirm Password" textFill="#ffffff">
                            <font>
                                <Font size="12.0" />
                            </font>
                        </Label>
                        <PasswordField fx:id="txtConfirmPassword" promptText="Confirm password" style="-fx-background-color: #0f3460; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #808080; -fx-background-radius: 5;">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </PasswordField>
                    </children>
                </VBox>
                
                <VBox spacing="5.0">
                    <children>
                        <Label text="Role" textFill="#ffffff">
                            <font>
                                <Font size="12.0" />
                            </font>
                        </Label>
                        <ComboBox fx:id="cmbRole" maxWidth="Infinity" promptText="Select role" style="-fx-background-color: #0f3460; -fx-background-radius: 5;" />
                    </children>
                </VBox>
                
                <Button fx:id="btnRegister" maxWidth="Infinity" mnemonicParsing="false" prefHeight="35.0" style="-fx-background-color: #e94560; -fx-text-fill: #ffffff; -fx-background-radius: 5; -fx-cursor: hand;" text="REGISTER">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </Button>
                
                <Hyperlink fx:id="linkLogin" style="-fx-text-fill: #e94560;" text="Already have an account? Login">
                    <font>
                        <Font size="11.0" />
                    </font>
                </Hyperlink>
                
                <Button fx:id="btnBack" mnemonicParsing="false" onAction="#handleBack" prefHeight="30.0" prefWidth="100.0" style="-fx-background-color: #607D8B; -fx-text-fill: #ffffff; -fx-background-radius: 5; -fx-cursor: hand;" text="Back">
                    <font>
                        <Font name="System Bold" size="12.0" />
                    </font>
                    <VBox.margin>
                        <Insets top="5.0" />
                    </VBox.margin>
                </Button>
            </children>
        </VBox>
    </children>
</AnchorPane>
