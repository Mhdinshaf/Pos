<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #1a1a2e;" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pos.controller.OrderController">
    <children>
        <VBox spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <!-- Header -->
                <Label text="PLACE ORDER" textFill="#e94560">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>

                <!-- Product Selection Section -->
                <VBox spacing="15.0" style="-fx-background-color: #16213e; -fx-background-radius: 10;">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                    <children>
                        <Label text="Add Product to Cart" textFill="#e94560">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>

                        <HBox spacing="20.0" alignment="CENTER_LEFT">
                            <children>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Product" textFill="#ffffff">
                                            <font>
                                                <Font size="12.0" />
                                            </font>
                                        </Label>
                                        <ComboBox fx:id="cmbProduct" maxWidth="Infinity" promptText="Select a product" style="-fx-background-color: #0f3460;" />
                                    </children>
                                </VBox>

                                <VBox spacing="5.0" prefWidth="120.0">
                                    <children>
                                        <Label text="Quantity" textFill="#ffffff">
                                            <font>
                                                <Font size="12.0" />
                                            </font>
                                        </Label>
                                        <TextField fx:id="txtQuantity" promptText="Qty" style="-fx-background-color: #0f3460; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #808080; -fx-background-radius: 5;">
                                            <font>
                                                <Font size="14.0" />
                                            </font>
                                        </TextField>
                                    </children>
                                </VBox>

                                <Button fx:id="btnAddToCart" mnemonicParsing="false" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #4CAF50; -fx-text-fill: #ffffff; -fx-background-radius: 5; -fx-cursor: hand;" text="Add to Cart">
                                    <font>
                                        <Font name="System Bold" size="13.0" />
                                    </font>
                                    <HBox.margin>
                                        <Insets top="18.0" />
                                    </HBox.margin>
                                </Button>
                            </children>
                        </HBox>

                        <Label fx:id="lblAvailableStock" text="Available Stock: -" textFill="#a0a0a0">
                            <font>
                                <Font size="12.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <!-- Cart Table Section -->
                <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Label text="Shopping Cart" textFill="#ffffff">
                                    <font>
                                        <Font name="System Bold" size="16.0" />
                                    </font>
                                </Label>
                            </children>
                        </HBox>

                        <TableView fx:id="tblCart" prefHeight="200.0" style="-fx-background-color: #16213e; -fx-control-inner-background: #16213e; -fx-table-cell-border-color: #0f3460;" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colProductName" prefWidth="300.0" text="Product Name" />
                                <TableColumn fx:id="colQuantity" prefWidth="100.0" text="Quantity" style="-fx-alignment: CENTER;" />
                                <TableColumn fx:id="colUnitPrice" prefWidth="150.0" text="Unit Price" style="-fx-alignment: CENTER_RIGHT;" />
                                <TableColumn fx:id="colSubtotal" prefWidth="150.0" text="Subtotal" style="-fx-alignment: CENTER_RIGHT;" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>

                <!-- Cart Actions and Total Section -->
                <VBox spacing="15.0" style="-fx-background-color: #16213e; -fx-background-radius: 10;">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_RIGHT" spacing="20.0">
                            <children>
                                <Label text="Total Amount:" textFill="#ffffff">
                                    <font>
                                        <Font name="System Bold" size="18.0" />
                                    </font>
                                </Label>
                                <Label fx:id="lblTotalAmount" text="Rs. 0.00" textFill="#4CAF50">
                                    <font>
                                        <Font name="System Bold" size="24.0" />
                                    </font>
                                </Label>
                            </children>
                        </HBox>

                        <HBox spacing="15.0" alignment="CENTER">
                            <children>
                                <Button fx:id="btnRemoveFromCart" mnemonicParsing="false" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #FF5722; -fx-text-fill: #ffffff; -fx-background-radius: 5; -fx-cursor: hand;" text="Remove Selected">
                                    <font>
                                        <Font name="System Bold" size="13.0" />
                                    </font>
                                </Button>
                                <Button fx:id="btnClearCart" mnemonicParsing="false" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #607D8B; -fx-text-fill: #ffffff; -fx-background-radius: 5; -fx-cursor: hand;" text="Clear Cart">
                                    <font>
                                        <Font name="System Bold" size="13.0" />
                                    </font>
                                </Button>
                                <Button fx:id="btnPlaceOrder" mnemonicParsing="false" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #e94560; -fx-text-fill: #ffffff; -fx-background-radius: 5; -fx-cursor: hand;" text="Place Order">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Button>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
