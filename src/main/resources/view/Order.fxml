<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="1000.0" style="-fx-background-color: #1a1f36;" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pos.controller.OrderController">
    <children>
        <HBox spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <!-- Left Panel - Product Selection -->
                <VBox spacing="15.0" HBox.hgrow="ALWAYS">
                    <children>
                        <!-- Header with Back Button -->
                        <HBox spacing="20.0" alignment="CENTER_LEFT">
                            <children>
                                <Button fx:id="btnBackToDashboard" mnemonicParsing="false" onAction="#handleBackToDashboard" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #3a86ff; -fx-text-fill: #ffffff; -fx-background-radius: 8; -fx-cursor: hand;" text="← Back">
                                    <font>
                                        <Font name="System Bold" size="12.0" />
                                    </font>
                                </Button>
                                <Label text="PLACE ORDER" textFill="#3a86ff">
                                    <font>
                                        <Font name="System Bold" size="24.0" />
                                    </font>
                                </Label>
                            </children>
                        </HBox>

                        <!-- Product Selection -->
                        <VBox spacing="15.0" style="-fx-background-color: #2d3250; -fx-background-radius: 10;">
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                            </padding>
                            <children>
                                <Label text="Add Product to Cart" textFill="#3a86ff">
                                    <font>
                                        <Font name="System Bold" size="16.0" />
                                    </font>
                                </Label>

                                <HBox spacing="15.0" alignment="CENTER_LEFT">
                                    <children>
                                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Search Product" textFill="#ffffff">
                                                    <font>
                                                        <Font size="12.0" />
                                                    </font>
                                                </Label>
                                                <TextField fx:id="txtProductSearch" maxWidth="Infinity" promptText="Type to search products..." style="-fx-background-color: #2d3250; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #808080; -fx-background-radius: 8; -fx-border-color: #3a86ff; -fx-border-radius: 8;">
                                                    <font>
                                                        <Font size="14.0" />
                                                    </font>
                                                </TextField>
                                                <Label text="Select Product" textFill="#ffffff">
                                                    <font>
                                                        <Font size="12.0" />
                                                    </font>
                                                    <VBox.margin>
                                                        <Insets top="5.0" />
                                                    </VBox.margin>
                                                </Label>
                                                <ComboBox fx:id="cmbProduct" maxWidth="Infinity" promptText="Choose a product" style="-fx-background-color: #2d3250; -fx-background-radius: 8; -fx-border-color: #3a86ff; -fx-border-radius: 8;" />
                                            </children>
                                        </VBox>

                                        <VBox spacing="5.0">
                                            <children>
                                                <Label text="Price" textFill="#ffffff">
                                                    <font>
                                                        <Font size="12.0" />
                                                    </font>
                                                </Label>
                                                <Label fx:id="lblProductPrice" text="Rs. 0.00" textFill="#4CAF50">
                                                    <font>
                                                        <Font name="System Bold" size="14.0" />
                                                    </font>
                                                </Label>
                                            </children>
                                        </VBox>

                                        <VBox spacing="5.0">
                                            <children>
                                                <Label text="Available" textFill="#ffffff">
                                                    <font>
                                                        <Font size="12.0" />
                                                    </font>
                                                </Label>
                                                <Label fx:id="lblAvailableStock" text="0" textFill="#a0a0a0">
                                                    <font>
                                                        <Font size="14.0" />
                                                    </font>
                                                </Label>
                                            </children>
                                        </VBox>

                                        <VBox spacing="5.0">
                                            <children>
                                                <Label text="Quantity" textFill="#ffffff">
                                                    <font>
                                                        <Font size="12.0" />
                                                    </font>
                                                </Label>
                                                <TextField fx:id="txtQuantity" prefWidth="100.0" promptText="Qty" style="-fx-background-color: #2d3250; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #808080; -fx-background-radius: 8; -fx-border-color: #3a86ff; -fx-border-radius: 8;">
                                                    <font>
                                                        <Font size="14.0" />
                                                    </font>
                                                </TextField>
                                            </children>
                                        </VBox>

                                        <Button fx:id="btnAddToCart" mnemonicParsing="false" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #4CAF50; -fx-text-fill: #ffffff; -fx-background-radius: 8; -fx-cursor: hand;" text="Add to Cart">
                                            <font>
                                                <Font name="System Bold" size="12.0" />
                                            </font>
                                            <VBox.margin>
                                                <Insets top="18.0" />
                                            </VBox.margin>
                                        </Button>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <!-- Cart Table -->
                        <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                            <children>
                                <Label text="Shopping Cart" textFill="#ffffff">
                                    <font>
                                        <Font name="System Bold" size="16.0" />
                                    </font>
                                </Label>
                                <TableView fx:id="tblCart" prefHeight="200.0" style="-fx-background-color: #2d3250; -fx-control-inner-background: #2d3250; -fx-table-cell-border-color: #1a1f36;" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colProductName" prefWidth="200.0" text="Product" />
                                        <TableColumn fx:id="colUnitPrice" prefWidth="100.0" text="Unit Price" style="-fx-alignment: CENTER-RIGHT;" />
                                        <TableColumn fx:id="colCartQuantity" prefWidth="80.0" text="Qty" style="-fx-alignment: CENTER;" />
                                        <TableColumn fx:id="colSubtotal" prefWidth="120.0" text="Subtotal" style="-fx-alignment: CENTER-RIGHT;" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <!-- Right Panel - Order Summary -->
                <VBox spacing="20.0" prefWidth="300.0" style="-fx-background-color: #2d3250; -fx-background-radius: 10;">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                    <children>
                        <Label text="Order Summary" textFill="#3a86ff">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                        </Label>

                        <!-- Order Details -->
                        <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                            <children>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Items in Cart:" textFill="#a0a0a0" HBox.hgrow="ALWAYS">
                                            <font>
                                                <Font size="14.0" />
                                            </font>
                                        </Label>
                                        <Label fx:id="lblItemCount" text="0" textFill="#ffffff">
                                            <font>
                                                <Font name="System Bold" size="14.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </HBox>

                                <VBox VBox.vgrow="ALWAYS" />

                                <!-- Total -->
                                <VBox spacing="5.0" style="-fx-background-color: #1a1f36; -fx-background-radius: 8;">
                                    <padding>
                                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                                    </padding>
                                    <children>
                                        <Label text="Total Amount" textFill="#a0a0a0">
                                            <font>
                                                <Font size="12.0" />
                                            </font>
                                        </Label>
                                        <Label fx:id="lblTotalAmount" text="Rs. 0.00" textFill="#4CAF50">
                                            <font>
                                                <Font name="System Bold" size="28.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <!-- Action Buttons -->
                        <VBox spacing="10.0">
                            <children>
                                <Button fx:id="btnRemoveFromCart" maxWidth="Infinity" mnemonicParsing="false" prefHeight="40.0" style="-fx-background-color: #ff6b6b; -fx-text-fill: #ffffff; -fx-background-radius: 8; -fx-cursor: hand;" text="Remove Selected">
                                    <font>
                                        <Font name="System Bold" size="13.0" />
                                    </font>
                                </Button>
                                <Button fx:id="btnClearCart" maxWidth="Infinity" mnemonicParsing="false" prefHeight="40.0" style="-fx-background-color: #3a86ff; -fx-text-fill: #ffffff; -fx-background-radius: 8; -fx-cursor: hand;" text="Clear Cart">
                                    <font>
                                        <Font name="System Bold" size="13.0" />
                                    </font>
                                </Button>
                                <Button fx:id="btnPlaceOrder" maxWidth="Infinity" mnemonicParsing="false" prefHeight="50.0" style="-fx-background-color: #4CAF50; -fx-text-fill: #ffffff; -fx-background-radius: 8; -fx-cursor: hand;" text="Place Order">
                                    <font>
                                        <Font name="System Bold" size="16.0" />
                                    </font>
                                </Button>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</AnchorPane>
